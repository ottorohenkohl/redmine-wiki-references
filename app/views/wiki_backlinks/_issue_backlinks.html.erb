<% backlinked_pages = RedmineWikiBacklinks::BacklinkFinder.referencing_pages(issue, User.current) %>

<% if backlinked_pages.any? %>
  <div id="wiki-backlinks" class="wiki-backlinks">
    <hr>
    <p><strong><%= l(:label_wiki_backlinks) %></strong></p>
    <ul>
      <% backlinked_pages.each do |page| %>
        <li>
          <%= link_to page.pretty_title, project_wiki_page_path(page.project, page.title) %>

          <span style="color:#888;">&mdash;<%= link_to page.project.name, project_path(page.project) %></span>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>
